<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:text="واتساب Proxy" />

    <LinearLayout
        android:id="@+id/layoutMainMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnRun"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="تشغيل الاختصار" />

        <Button
            android:id="@+id/btnRecord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="تسجيل مسار جديد" />

        <Button
            android:id="@+id/btnClearPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="حذف المسار المسجل" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutRecording"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/recordingStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="جاري التسجيل..." />

        <Button
            android:id="@+id/btnStopSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="إيقاف وحفظ" />

        <Button
            android:id="@+id/btnCancelRecording"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="إلغاء" />

    </LinearLayout>

</LinearLayout>
